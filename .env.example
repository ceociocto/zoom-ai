# Zoom API配置 (如使用Zoom SDK)
ZOOM_API_KEY=your_api_key
ZOOM_API_SECRET=your_api_secret
ZOOM_SDK_JWT=your_jwt_token

# TTS服务配置
TTS_PROVIDER=edge  # edge, azure, elevenlabs, coqui
AZURE_TTS_KEY=your_azure_key
AZURE_TTS_REGION=eastasia
ELEVENLABS_API_KEY=your_elevenlabs_key

# GLM TTS 配置
GLM_TTS_API_KEY=your_glm_tts_api_key_here
GLM_TTS_API_URL=https://open.bigmodel.cn/api/paas/v4/audio/speech

# Qwen3-TTS 配置 (MLX 本地 TTS，仅支持 Apple Silicon)
# 模型路径 - 可以是 HuggingFace 模型 ID 或本地路径
# 例如: Qwen/Qwen3-TTS-12Hz-1.7B-Base
# 或本地路径: /path/to/models/Qwen3-TTS-12Hz-1.7B-Base
QWEN3_TTS_MODEL_PATH=Qwen/Qwen3-TTS-12Hz-1.7B-Base/Volumes/sn7100/jerry/.cache/huggingface/hub/models--Qwen--Qwen3-TTS-12Hz-1.7B-Base/snapshots/downloaded

# LLM 配置 (用于问答) - 智谱 API
LLM_PROVIDER=custom
LLM_MODEL=glm-tts
CUSTOM_LLM_API_KEY=your_custom_llm_api_key_here
CUSTOM_LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/

# 语音助手配置 (会议问答)
VOICE_ASSISTANT_ENABLED=true
WAKE_WORD=Hey Zoom AI
CONTEXT_WINDOW_MINUTES=5
TTS_VOICE=zh-CN-XiaoxiaoNeural

# 虚拟人配置
AVATAR_MODEL=sadtalker  # sadtalker, musetalk
AVATAR_IMAGE_PATH=./assets/avatar.png
AVATAR_VIDEO_PATH=./assets/avatar_idle.mp4

# 虚拟摄像头配置
VIRTUAL_CAMERA_DEVICE=/dev/video0
V4L2LOOPBACK_DEVICES=4

# 视频输出配置
OUTPUT_WIDTH=1280
OUTPUT_HEIGHT=720
OUTPUT_FPS=30

# 日志配置
LOG_LEVEL=INFO
LOG_PATH=./logs

# 浏览器配置
BROWSER_HEADLESS=false  # 是否使用无头模式（不显示浏览器窗口）
